{
  "name": "zero-agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Desktop-first AI coding agent with a thin scriptable CLI. Bring your own model.",
  "homepage": "https://github.com/your-org/zero-agent",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "desktop:dev": "pnpm --filter @zero-agent/desktop tauri:dev",
    "desktop:build": "pnpm --filter @zero-agent/desktop tauri:build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
