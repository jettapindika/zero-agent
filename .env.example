# ----------------------------------------------------------------------------
# Zero — environment variables
# Copy to .env (or export in your shell) before running `zero` / `zero-server`.
# Variables that start with ZERO_ are read by the Go daemon directly.
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Provider — Bring Your Own Model
# ----------------------------------------------------------------------------
# Zero talks to any OpenAI-compatible endpoint that exposes:
#   GET  <BASE_URL>/models
#   POST <BASE_URL>/chat/completions
#
# Tested providers (any of these will work):
#   - OpenAI:                 https://api.openai.com/v1
#   - Anthropic via proxy:    use a router like LiteLLM or OpenRouter
#   - Local Ollama:           http://127.0.0.1:11434/v1   (key may be anything)
#   - Local llama.cpp server: http://127.0.0.1:8080/v1
#   - LM Studio:              http://127.0.0.1:1234/v1
#   - Self-hosted vLLM:       http://<host>:8000/v1
#
# The desktop app's Model Picker will live-fetch this `/models` URL and let
# the user pick whatever your provider returns.
ZERO_ROUTER_BASE_URL=https://api.openai.com/v1
ZERO_ROUTER_API_KEY=

# Optional: override the default model id the agent uses on a fresh session.
# Leave blank to let Zero pick the first model returned by /models.
# ZERO_DEFAULT_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# Multi-user mode (Google sign-in). Off by default — single-user, no login.
# Flip to true to require Google login on every non-public route. Any Google
# account that successfully authenticates is auto-onboarded with role: "user".
# DEV_EMAILS controls who additionally gets role: "dev" (Dev tab + /dev/*),
# it does NOT restrict who can sign in.
#
# The Google OAuth client is bundled with Zero (loopback / Desktop OAuth
# pattern with PKCE). You do NOT need to create your own Google Cloud
# project. SESSION_SECRET is the only thing you must provide.
#
# To use your OWN Google OAuth client instead, set GOOGLE_CLIENT_ID +
# GOOGLE_CLIENT_SECRET below — they override the bundled defaults.
#
# Public routes (still reachable without a cookie):
#   /health, /openapi.json, /events, /auth/*
# ----------------------------------------------------------------------------
ZERO_AUTH_ENABLED=false

# 32+ random bytes used to HMAC-sign the session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Comma-separated list of dev-role accounts. Members of this list see the
# "Dev" tab in the SidePanel and can hit /dev/* endpoints.
DEV_EMAILS=

# OPTIONAL: bring your own Google OAuth client. Leave blank to use the
# bundled defaults. The daemon is the trusted backend — the desktop never
# sees CLIENT_SECRET.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where Google redirects after consent. Must exactly match an Authorized
# Redirect URI in the OAuth client config. Loopback (127.0.0.1) is exempt
# from Google's HTTPS requirement.
GOOGLE_CALLBACK_URL=http://127.0.0.1:8910/auth/google/callback

# ----------------------------------------------------------------------------
# Optional: store auth accounts in Supabase Postgres instead of local SQLite
# When unset, users + auth_sessions live in ~/.zero/zero.db (SQLite).
# When set, the daemon connects to Supabase Postgres for auth tables only.
# Chat data (projects, sessions, messages, parts) always stays in SQLite.
#
# DSN format (Project Settings → Database → Connection string → URI):
#   postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# Apply schema with one of:
#   supabase db push                                     (after supabase link)
#   psql "$ZERO_SUPABASE_DB_URL" -f services/core/supabase/migrations/00001_auth.sql
# ----------------------------------------------------------------------------
# ZERO_SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.<your-project-ref>.supabase.co:5432/postgres
