# ----------------------------------------------------------------------------
# Zero — environment variables
# Copy to .env (or export in your shell) before running `zero` / `zero-server`.
# Variables that start with ZERO_ are read by the Go daemon directly.
# ----------------------------------------------------------------------------

# Provider (9router or any OpenAI-compatible endpoint)
ZERO_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
ZERO_ROUTER_API_KEY=sk_9router

# ----------------------------------------------------------------------------
# Optional: Google sign-in for the desktop app
# Off by default. Flip ZERO_AUTH_ENABLED=true to require login on every
# non-public route. Public routes (still reachable without a cookie):
#   /health, /openapi.json, /events, /auth/*
# ----------------------------------------------------------------------------
ZERO_AUTH_ENABLED=false

# Google OAuth 2.0 client (Web Application). The daemon is the trusted
# backend — the desktop never sees CLIENT_SECRET.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where Google redirects after consent. Must exactly match an Authorized
# Redirect URI in the OAuth client config. Loopback (127.0.0.1) is exempt
# from Google's HTTPS requirement.
GOOGLE_CALLBACK_URL=http://127.0.0.1:8910/auth/google/callback

# 32+ random bytes used to HMAC-sign the session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Comma-separated list of dev-role accounts. Members of this list see the
# "Dev" tab in the SidePanel and can hit /dev/* endpoints. DEV_EMAIL is a
# fallback for the original spec's single-email form.
DEV_EMAILS=jettabackupacc1@gmail.com
# DEV_EMAIL=jettabackupacc1@gmail.com
