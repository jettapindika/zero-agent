{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zero",
  "version": "0.1.0",
  "identifier": "dev.zero-agent.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:3200",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zero",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8910 http://localhost:8910; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/zero-server"],
    "icon": []
  }
}
